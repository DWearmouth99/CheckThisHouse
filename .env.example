# Primary: Gemini (Google AI Studio key)
# https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Optional — defaults to gemini-3.1-pro-preview
# GEMINI_MODEL="gemini-3.1-pro-preview"
# GEMINI_MODEL="gemini-3.5-flash"

# Optional fallback
# OPENAI_API_KEY="sk-..."

# Public site URL (used for Stripe success/cancel redirects)
APP_URL="http://localhost:3000"

# --- Stripe paywall (pay-per-report) ---
# Dashboard → Developers → API keys (Test mode while developing)
# https://dashboard.stripe.com/test/apikeys
# Paste the FULL keys (long strings). Do not leave "..." placeholders.
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
# Required for on-site popup checkout (Publishable key = starts with pk_)
STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
# Branding (logo + colours): Dashboard → Settings → Branding
# https://dashboard.stripe.com/settings/branding

# Price in pence (499 = £4.99). Ignored if STRIPE_PRICE_ID is set.
REPORT_PRICE_PENCE="499"
# Optional: use a Price you created in Stripe Dashboard instead of dynamic price_data
# STRIPE_PRICE_ID="price_..."

# Optional webhook (local: stripe listen --forward-to localhost:3000/api/stripe/webhook)
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Ideal Postcodes — UK address autocomplete (https://ideal-postcodes.co.uk/)
# Keep this secret. Suggestions are free; resolving a selected address uses a credit.
# IDEAL_POSTCODES_API_KEY="ak_REPLACE_ME"

# Optional: England & Wales EPC Open Data API (richer than the public HTML register).
# Preferred (new GOV.UK One Login portal): copy the Bearer token from
#   https://get-energy-performance-data.communities.gov.uk/ → Use a developer API
# Paste the token only (with or without a leading "Bearer " — both work).
# EPC_API_BEARER="eyJhbGciOi..."
# Legacy Basic auth (older Open Data Communities accounts) — only if you still have email+key:
# EPC_API_EMAIL="you@example.com"
# EPC_API_KEY="your_epc_api_key"
# Without credentials, CheckThisHouse still matches EPC band/address via the public register HTML.

# Set to true ONLY for local free testing without Stripe
# PAYWALL_DISABLED="true"
